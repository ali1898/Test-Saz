{
  "name": "testsaz",
  "version": "1.0.0",
  "description": "Testsaz — AI-Powered Cypress Test Generator (POM, BDD, Allure, AI)",
  "workspaces": [
    "packages/core",
    "packages/cli"
  ],
  "bin": {
    "qa": "./packages/cli/dist/index.js"
  },
  "files": [
    "packages/cli/dist",
    "packages/core/dist",
    "packages/*/package.json",
    "qa.cmd",
    "package.json",
    "README.md"
  ],
  "scripts": {
    "build": "npm run build --workspaces",
    "build:core": "npm run build --workspace @testsaz/core",
    "build:cli": "npm run build --workspace @testsaz/cli",
    "dev:cli": "npm run dev --workspace @testsaz/cli",
    "unlink": "npm unlink -g qa @testsaz/cli @testsaz/core",
    "qa": "node packages/cli/dist/index.js",
    "prepack": "npm run build",
    "clean": "rimraf packages/*/dist packages/*/node_modules"
  },
  "devDependencies": {
    "marked": "^18.0.5",
    "rimraf": "^5.0.5",
    "typescript": "^5.4.5"
  },
  "engines": {
    "node": ">=18"
  }
}
